% Unless necessary, do not edit this file.

\ProvidesPackage{requirements}

\RequirePackage{pdfpages}
\RequirePackage{mathptmx}
\RequirePackage[left=2.50cm, right=2.50cm, top=2.50cm, bottom=2.50cm]{geometry}
\setlength{\headheight}{27.18207pt}
\addtolength{\topmargin}{-15.18207pt}
\RequirePackage{graphicx}
\RequirePackage{array}
\RequirePackage{setspace}
\RequirePackage{amsmath}
%%%
% \RequirePackage{ctex}
%%%
\RequirePackage{xeCJK}
\setCJKmainfont[
  Path = fonts/,
  Extension = .ttf,
  BoldFont = CuSong
]{SIMSUN}

\RequirePackage{fontspec}
\setmainfont{Times New Roman}
\newfontfamily\timesfont{Times New Roman}
\newfontfamily\calibrifont[
    Path = fonts/ ,
    Extension = .ttf ,
    BoldFont = Calibrib,
    ItalicFont = Calibrii,
    BoldItalicFont = Calibriz
]{Calibri} % only table of contents use Calibri

\RequirePackage{enumerate}
\RequirePackage{listings}
\RequirePackage{multirow}
\RequirePackage{makeidx}
\RequirePackage{xcolor}
\RequirePackage{subfigure}
\PassOptionsToPackage{hyphens}{url}

\RequirePackage[numbers,square,sort&compress]{natbib}
% \bibliographystyle{IEEEtran} % Provides for the format of IEEE references
\bibliographystyle{vancouver} % the Vancouver referencing style

\RequirePackage{abstract}
\setlength{\absleftindent}{0pt}
\setlength{\absrightindent}{0pt}

\RequirePackage{fancyhdr}

\renewcommand{\headrulewidth}{0pt}
\pagestyle{fancy}
\fancyhf{}           % Clear all header and footer fields
\fancyfoot[R]{\thepage} % Place page number on the bottom-right

\setlength{\parindent}{0pt} % Set paragraph indentation to 0
\setlength{\parskip}{6pt} % Set paragraph spacing to 6 pt

\usepackage{titlesec}
\titlespacing*{\subsection}{0pt}{12pt}{6pt} % subsection title spacing
\titlespacing*{\section}{0pt}{12pt}{6pt} % section title spacing

\RequirePackage[subfigure]{tocloft} % The template uses the subfigure library. Add this option to prevent potential conflicts
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}
\renewcommand{\cftsubsecfont}{\bfseries} % Sets subsection to appear in bold in the directory
\renewcommand{\cftsubsecpagefont}{\bfseries} % It is also desired that page numbers of subsections in the catalog be displayed in bold
\renewcommand{\cftsubsubsecfont}{\small\calibrifont}
\renewcommand{\cftsubsubsecpagefont}{\small\calibrifont}
\renewcommand{\cfttoctitlefont}{\hfill\Large\timesfont} % set ToC title font

\renewcommand{\cftaftertoctitle}{\hfill}
\renewcommand{\cftdotsep}{0.05} % controls density of the dots
\setlength{\cftbeforesecskip}{6pt} % line spacing before section
\setlength{\cftbeforesubsecskip}{6pt} % line specing before subsection
\setlength{\cftbeforesubsubsecskip}{-1.5pt} % line specing before subsubsection (very tight)
\cftsetindents{subsection}{1em}{2.3em} % space between 1.1 and Format, etc (widened for two-digit subsection numbers)
\cftsetindents{subsubsection}{3.3em}{2.5em} % space between 1.1.1 and Format for headings, etc
\renewcommand{\contentsname}{Table of Contents}

\usepackage[hidelinks]{hyperref}  % hide boarders on links
\usepackage{etoc}
