\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Latency and Control-Plane Overhead}{30}{subsection.4.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Mean end-to-end latency by payload ($n = 30$ runs $\times $ 2000 requests). $\Delta $ columns report the relative change against the \texttt  {userspace} baseline on the same row; $p$-values are two-sided Welch's $t$-tests against that baseline, \textsuperscript  {ns} $= p > 0.05$. Bold marks the row minimum.}}{31}{table.6}\protected@file@percent }
\newlabel{tab:latency}{{6}{31}{Mean end-to-end latency by payload ($n = 30$ runs $\times $ 2000 requests). $\Delta $ columns report the relative change against the \texttt {userspace} baseline on the same row; $p$-values are two-sided Welch's $t$-tests against that baseline, \textsuperscript {ns} $= p > 0.05$. Bold marks the row minimum}{table.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Latency summary across the three systems at 100~B, 10~KiB, and 1~MiB payloads ($n = 30$ independent runs of 2000 requests, error bars 95\% CI). Panel (a): mean end-to-end latency on a log y-axis so sub-millisecond gaps at small payloads remain visible alongside the 1~MiB values. Panel (b): $p_{95}$ latency; the three systems are indistinguishable at 100~B and 10~KiB, and the kernel $p_{95}$ sits below both baselines at 1~MiB. Panel (c): mean-latency ratio against the \texttt  {userspace} baseline, zoomed around the parity line; \texttt  {seccomp} sits above parity at every payload size, while the kernel path only crosses below parity at 1~MiB. Panel (d): control-plane stage zoom in $\mu $s; session lookup is comparable across systems, and kernel arbitration adds roughly $+26.7\,\mu $s above the userspace path but is still two orders of magnitude below tool execution.}}{31}{figure.4}\protected@file@percent }
\newlabel{fig:chapter4-latency}{{4}{31}{Latency summary across the three systems at 100~B, 10~KiB, and 1~MiB payloads ($n = 30$ independent runs of 2000 requests, error bars 95\% CI). Panel (a): mean end-to-end latency on a log y-axis so sub-millisecond gaps at small payloads remain visible alongside the 1~MiB values. Panel (b): $p_{95}$ latency; the three systems are indistinguishable at 100~B and 10~KiB, and the kernel $p_{95}$ sits below both baselines at 1~MiB. Panel (c): mean-latency ratio against the \texttt {userspace} baseline, zoomed around the parity line; \texttt {seccomp} sits above parity at every payload size, while the kernel path only crosses below parity at 1~MiB. Panel (d): control-plane stage zoom in $\mu $s; session lookup is comparable across systems, and kernel arbitration adds roughly $+26.7\,\mu $s above the userspace path but is still two orders of magnitude below tool execution}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Empirical CDF of per-run mean latency ($n = 30$ runs per payload per system), with each subplot auto-scaled in x so the relevant regime is visible. Overlapping curves at 100~B and 10~KiB indicate that the per-run means are indistinguishable across systems; at 1~MiB the \texttt  {seccomp} curve shifts rightward and the \texttt  {kernel} curve lies to the left of \texttt  {userspace}, with no heavy right tail on the kernel path.}}{33}{figure.5}\protected@file@percent }
\newlabel{fig:chapter4-latency-ecdf}{{5}{33}{Empirical CDF of per-run mean latency ($n = 30$ runs per payload per system), with each subplot auto-scaled in x so the relevant regime is visible. Overlapping curves at 100~B and 10~KiB indicate that the per-run means are indistinguishable across systems; at 1~MiB the \texttt {seccomp} curve shifts rightward and the \texttt {kernel} curve lies to the left of \texttt {userspace}, with no heavy right tail on the kernel path}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Kernel path ablation at realistic registry scale ($N = 1024$ tools, $M = 64$ agents). The leftmost bar is the measured noise floor from the \texttt  {KMCP\_\allowbreak  CMD\_\allowbreak  NOOP} handler, which establishes the irreducible Generic Netlink round-trip cost. The \texttt  {full} bar is the complete \texttt  {TOOL\_\allowbreak  REQUEST} arbitration path; \texttt  {skip\_\allowbreak  lookups} disables the tool and agent registry walks. The two \texttt  {ticket\_\allowbreak  trigger} bars exercise a high-risk tool whose execution is gated by the approval-ticket machinery, with and without the approval branch bypassed. All error bars are 95\% bootstrap CIs across $n = 10$ repetitions.}}{33}{figure.6}\protected@file@percent }
\newlabel{fig:chapter4-ablation}{{6}{33}{Kernel path ablation at realistic registry scale ($N = 1024$ tools, $M = 64$ agents). The leftmost bar is the measured noise floor from the \texttt {KMCP\_\allowbreak CMD\_\allowbreak NOOP} handler, which establishes the irreducible Generic Netlink round-trip cost. The \texttt {full} bar is the complete \texttt {TOOL\_\allowbreak REQUEST} arbitration path; \texttt {skip\_\allowbreak lookups} disables the tool and agent registry walks. The two \texttt {ticket\_\allowbreak trigger} bars exercise a high-risk tool whose execution is gated by the approval-ticket machinery, with and without the approval branch bypassed. All error bars are 95\% bootstrap CIs across $n = 10$ repetitions}{figure.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Paired per-stage ablation deltas. Each row alternates a baseline mode and a bypass mode request-by-request inside a single phase; the $\Delta $ column is the mean of $\text  {baseline}_i - \text  {bypass}_i$ across all pairs. BH-corrected paired $t$-tests are reported across all four comparisons.}}{34}{table.7}\protected@file@percent }
\newlabel{tab:ablation-stages}{{7}{34}{Paired per-stage ablation deltas. Each row alternates a baseline mode and a bypass mode request-by-request inside a single phase; the $\Delta $ column is the mean of $\text {baseline}_i - \text {bypass}_i$ across all pairs. BH-corrected paired $t$-tests are reported across all four comparisons}{table.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Paired per-stage deltas across the four ablation comparisons. The first two bars are the meaningful stage costs (registry+agent lookup and the approval-ticket body); the last two are methodology consistency checks against dead guard bodies and are expected to fall on zero.}}{34}{figure.7}\protected@file@percent }
\newlabel{fig:chapter4-ablation-stages}{{7}{34}{Paired per-stage deltas across the four ablation comparisons. The first two bars are the meaningful stage costs (registry+agent lookup and the approval-ticket body); the last two are methodology consistency checks against dead guard bodies and are expected to fall on zero}{figure.7}{}}
