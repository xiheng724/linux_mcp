\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Mean end-to-end latency by payload ($n = 30$ runs $\times $ 2000 requests). $\Delta $ columns report the relative change against the \texttt  {userspace} baseline on the same row; $p$-values are two-sided Welch's $t$-tests against that baseline, \textsuperscript  {ns} $= p > 0.05$. Bold marks the row minimum.}}{28}{table.6}\protected@file@percent }
\newlabel{tab:latency}{{6}{28}{Mean end-to-end latency by payload ($n = 30$ runs $\times $ 2000 requests). $\Delta $ columns report the relative change against the \texttt {userspace} baseline on the same row; $p$-values are two-sided Welch's $t$-tests against that baseline, \textsuperscript {ns} $= p > 0.05$. Bold marks the row minimum}{table.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Latency summary across the three systems at 100~B, 10~KiB, and 1~MiB payloads ($n = 30$ independent runs of 2000 requests, error bars 95\% CI). Panel (a): mean end-to-end latency on a log y-axis so sub-millisecond gaps at small payloads remain visible alongside the 1~MiB values. Panel (b): $p_{95}$ latency; the three systems are indistinguishable at 100~B and 10~KiB, and the kernel $p_{95}$ sits below both baselines at 1~MiB. Panel (c): mean-latency ratio against the \texttt  {userspace} baseline, zoomed around the parity line; \texttt  {seccomp} sits above parity at every payload size, while the kernel path only crosses below parity at 1~MiB. Panel (d): per-payload stage stack in $\mu $s, with three sub-axes auto-scaled per payload; each bar decomposes one system into session-lookup, arbitration, and tool-exec. The annotation above each kernel bar reports the absolute kernel arbitration cost (\num {28}~$\mu $s at 100~B and 10~KiB, \num {38}~$\mu $s at 1~MiB), which is the only stage with a meaningful inter-system delta and remains roughly one order of magnitude below tool execution at small payloads (tool exec / arbitration $\approx $ 10$\times $) and at least two orders of magnitude below at 1~MiB ($\approx $ 102$\times $ against tool execution alone, and $\approx $ 197$\times $ against full end-to-end latency).}}{30}{figure.4}\protected@file@percent }
\newlabel{fig:chapter4-latency}{{4}{30}{Latency summary across the three systems at 100~B, 10~KiB, and 1~MiB payloads ($n = 30$ independent runs of 2000 requests, error bars 95\% CI). Panel (a): mean end-to-end latency on a log y-axis so sub-millisecond gaps at small payloads remain visible alongside the 1~MiB values. Panel (b): $p_{95}$ latency; the three systems are indistinguishable at 100~B and 10~KiB, and the kernel $p_{95}$ sits below both baselines at 1~MiB. Panel (c): mean-latency ratio against the \texttt {userspace} baseline, zoomed around the parity line; \texttt {seccomp} sits above parity at every payload size, while the kernel path only crosses below parity at 1~MiB. Panel (d): per-payload stage stack in $\mu $s, with three sub-axes auto-scaled per payload; each bar decomposes one system into session-lookup, arbitration, and tool-exec. The annotation above each kernel bar reports the absolute kernel arbitration cost (\num {28}~$\mu $s at 100~B and 10~KiB, \num {38}~$\mu $s at 1~MiB), which is the only stage with a meaningful inter-system delta and remains roughly one order of magnitude below tool execution at small payloads (tool exec / arbitration $\approx $ 10$\times $) and at least two orders of magnitude below at 1~MiB ($\approx $ 102$\times $ against tool execution alone, and $\approx $ 197$\times $ against full end-to-end latency)}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Empirical CDF of per-run mean latency ($n = 30$ runs per payload per system), with each subplot auto-scaled in x so the relevant regime is visible. Overlapping curves at 100~B and 10~KiB indicate that the per-run means are indistinguishable across systems; at 1~MiB the \texttt  {seccomp} curve shifts rightward and the \texttt  {kernel} curve lies to the left of \texttt  {userspace}, with no heavy right tail on the kernel path.}}{31}{figure.5}\protected@file@percent }
\newlabel{fig:chapter4-latency-ecdf}{{5}{31}{Empirical CDF of per-run mean latency ($n = 30$ runs per payload per system), with each subplot auto-scaled in x so the relevant regime is visible. Overlapping curves at 100~B and 10~KiB indicate that the per-run means are indistinguishable across systems; at 1~MiB the \texttt {seccomp} curve shifts rightward and the \texttt {kernel} curve lies to the left of \texttt {userspace}, with no heavy right tail on the kernel path}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Kernel path ablation at realistic registry scale ($N = 1024$ tools, $M = 64$ agents). Bar heights report median RTT ($p_{50}$) over $n = 10$ repetitions ($\geq $\,1000 requests per cell, $\geq $\,2000 for the NOOP floor); error bars are omitted because the CI95 column in the source data describes the mean rather than the median. The leftmost bar is the measured noise floor from the \texttt  {KMCP\_\allowbreak  CMD\_\allowbreak  NOOP} handler, which establishes the irreducible Generic Netlink round-trip cost. The \texttt  {full} bar is the complete \texttt  {TOOL\_\allowbreak  REQUEST} arbitration path; \texttt  {skip\_\allowbreak  lookups} disables the tool and agent registry walks; the two \texttt  {ticket\_\allowbreak  trigger} bars exercise a high-risk tool whose execution is gated by the approval-ticket machinery, with and without the approval branch bypassed; \texttt  {skip\_\allowbreak  hash} and \texttt  {skip\_\allowbreak  binding} bypass the hash and binding-mismatch guard bodies (dead code under benign workload). The dotted line and inline annotation visualise the +\num {4.334}~$\mu $s arbitration delta over the NOOP floor that paragraph above quantifies.}}{32}{figure.6}\protected@file@percent }
\newlabel{fig:chapter4-ablation}{{6}{32}{Kernel path ablation at realistic registry scale ($N = 1024$ tools, $M = 64$ agents). Bar heights report median RTT ($p_{50}$) over $n = 10$ repetitions ($\geq $\,1000 requests per cell, $\geq $\,2000 for the NOOP floor); error bars are omitted because the CI95 column in the source data describes the mean rather than the median. The leftmost bar is the measured noise floor from the \texttt {KMCP\_\allowbreak CMD\_\allowbreak NOOP} handler, which establishes the irreducible Generic Netlink round-trip cost. The \texttt {full} bar is the complete \texttt {TOOL\_\allowbreak REQUEST} arbitration path; \texttt {skip\_\allowbreak lookups} disables the tool and agent registry walks; the two \texttt {ticket\_\allowbreak trigger} bars exercise a high-risk tool whose execution is gated by the approval-ticket machinery, with and without the approval branch bypassed; \texttt {skip\_\allowbreak hash} and \texttt {skip\_\allowbreak binding} bypass the hash and binding-mismatch guard bodies (dead code under benign workload). The dotted line and inline annotation visualise the +\num {4.334}~$\mu $s arbitration delta over the NOOP floor that paragraph above quantifies}{figure.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Paired per-stage ablation deltas. Each row alternates a baseline mode and a bypass mode request-by-request inside a single phase; the $\Delta $ column is the mean of $\text  {baseline}_i - \text  {bypass}_i$ across all pairs. BH-corrected paired $t$-tests are reported across all four comparisons.}}{33}{table.7}\protected@file@percent }
\newlabel{tab:ablation-stages}{{7}{33}{Paired per-stage ablation deltas. Each row alternates a baseline mode and a bypass mode request-by-request inside a single phase; the $\Delta $ column is the mean of $\text {baseline}_i - \text {bypass}_i$ across all pairs. BH-corrected paired $t$-tests are reported across all four comparisons}{table.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Paired per-stage deltas across the four ablation comparisons. The first two bars are the meaningful stage costs (registry+agent lookup and the approval-ticket body); the last two are methodology consistency checks against dead guard bodies and are expected to fall on zero.}}{33}{figure.7}\protected@file@percent }
\newlabel{fig:chapter4-ablation-stages}{{7}{33}{Paired per-stage deltas across the four ablation comparisons. The first two bars are the meaningful stage costs (registry+agent lookup and the approval-ticket body); the last two are methodology consistency checks against dead guard bodies and are expected to fall on zero}{figure.7}{}}
