\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Registry register-path per-tool cost as a function of registry size $N$, with $95\%$ CI error bars. The dashed line is the asymptotic per-tool cost $b = 6.010$~$\mu $s, taken as the slope of the linear fit $\text  {total\_ms}(N) = a + b N$ used in Section~\ref {sec:registry-scaling}. We do not overlay the per-tool fit curve $a/N + b$: the OLS-derived intercept $a$ is slightly negative (an artefact of the fit being dominated by large-$N$ residuals in the millisecond range), so the curve would reach the asymptote from below while the data reaches it from above. Measured per-tool cost stays within roughly $\pm 1$~$\mu $s of the asymptote across three orders of magnitude of $N$ and is indistinguishable from a constant for $N \geq 2^7$.}}{36}{figure.9}\protected@file@percent }
\newlabel{fig:chapter4-registry-curve}{{9}{36}{Registry register-path per-tool cost as a function of registry size $N$, with $95\%$ CI error bars. The dashed line is the asymptotic per-tool cost $b = 6.010$~$\mu $s, taken as the slope of the linear fit $\text {total\_ms}(N) = a + b N$ used in Section~\ref {sec:registry-scaling}. We do not overlay the per-tool fit curve $a/N + b$: the OLS-derived intercept $a$ is slightly negative (an artefact of the fit being dominated by large-$N$ residuals in the millisecond range), so the curve would reach the asymptote from below while the data reaches it from above. Measured per-tool cost stays within roughly $\pm 1$~$\mu $s of the asymptote across three orders of magnitude of $N$ and is indistinguishable from a constant for $N \geq 2^7$}{figure.9}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Security Evaluation}{36}{subsection.4.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Steady-state \texttt  {tool\_id} lookup latency as a function of registry size $N$, on a log-$N$ axis. The fitted log-linear slope is $2.9\times 10^{-5}$~ms per doubling (bootstrap 95\% CI $[-2\times 10^{-6}, +6.1\times 10^{-5}]$, containing zero), consistent with the $O(1)$ xarray lookup invariant.}}{37}{figure.10}\protected@file@percent }
\newlabel{fig:chapter4-registry-lookup}{{10}{37}{Steady-state \texttt {tool\_id} lookup latency as a function of registry size $N$, on a log-$N$ axis. The fitted log-linear slope is $2.9\times 10^{-5}$~ms per doubling (bootstrap 95\% CI $[-2\times 10^{-6}, +6.1\times 10^{-5}]$, containing zero), consistent with the $O(1)$ xarray lookup invariant}{figure.10}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Category-level attack outcomes by system (130 attempts each: 3 spoof $+$ 5 replay $+$ 3 substitution $+$ 2 escalation, $\times \,10$ repeats). ``Bypasses'' counts attempts that circumvented the intended control. 95\% Clopper--Pearson confidence intervals on the bypass rate are reported in the last column. The 84.6\% userspace rate is \emph  {not} a uniform per-case bypass: 11 of the 13 case rows are admitted in full ($10/10$ each $= 110$), while two cases (\texttt  {spoof / session\_token\_theft} and \texttt  {replay / cross\_tool\_ticket\_reuse}) are blocked by orthogonal in-process checks even on the unhardened user-space mediator and contribute 0 admissions to the headline. The full per-case decomposition is plotted in Figure~\ref {fig:chapter4-security}. User-space rates reflect the per-category instrumented weakening described below; they are \emph  {not} the performance of a fully hardened user-space implementation.}}{37}{table.9}\protected@file@percent }
\newlabel{tab:attacks}{{9}{37}{Category-level attack outcomes by system (130 attempts each: 3 spoof $+$ 5 replay $+$ 3 substitution $+$ 2 escalation, $\times \,10$ repeats). ``Bypasses'' counts attempts that circumvented the intended control. 95\% Clopper--Pearson confidence intervals on the bypass rate are reported in the last column. The 84.6\% userspace rate is \emph {not} a uniform per-case bypass: 11 of the 13 case rows are admitted in full ($10/10$ each $= 110$), while two cases (\texttt {spoof / session\_token\_theft} and \texttt {replay / cross\_tool\_ticket\_reuse}) are blocked by orthogonal in-process checks even on the unhardened user-space mediator and contribute 0 admissions to the headline. The full per-case decomposition is plotted in Figure~\ref {fig:chapter4-security}. User-space rates reflect the per-category instrumented weakening described below; they are \emph {not} the performance of a fully hardened user-space implementation}{table.9}{}}
\citation{greshake2023prompt,liu2023prompt}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Attack bypass outcome per case and system (13 per-case rows grouped by attack type, 10 repetitions per cell). Dark cells indicate the attempt was fully blocked; white cells with a $\mathrm  {successes}/\mathrm  {attempts}$ label indicate a full bypass; hatched white cells indicate a partial bypass. The \texttt  {kernel} column is uniformly blocked across all 13 per-case rows, while the two user-space baselines permit bypasses on the specific checks that their instrumented tamper profiles relax.}}{38}{figure.11}\protected@file@percent }
\newlabel{fig:chapter4-security}{{11}{38}{Attack bypass outcome per case and system (13 per-case rows grouped by attack type, 10 repetitions per cell). Dark cells indicate the attempt was fully blocked; white cells with a $\mathrm {successes}/\mathrm {attempts}$ label indicate a full bypass; hatched white cells indicate a partial bypass. The \texttt {kernel} column is uniformly blocked across all 13 per-case rows, while the two user-space baselines permit bypasses on the specific checks that their instrumented tamper profiles relax}{figure.11}{}}
