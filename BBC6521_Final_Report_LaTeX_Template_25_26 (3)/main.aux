\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Principal messages on the \texttt  {llm-app}--\texttt  {mcpd} JSON-RPC channel. All messages are framed with a 4-byte big-endian length prefix. The \texttt  {tool:exec} response carries the kernel's \texttt  {decision} field (\texttt  {ALLOW}/\texttt  {DENY}/\texttt  {DEFER}) and, on deferral, a \texttt  {ticket\_id} the client uses to issue the subsequent \texttt  {approval\_reply}.}}{18}{table.4}\protected@file@percent }
\newlabel{tab:llm-mcpd}{{4}{18}{Principal messages on the \texttt {llm-app}--\texttt {mcpd} JSON-RPC channel. All messages are framed with a 4-byte big-endian length prefix. The \texttt {tool:exec} response carries the kernel's \texttt {decision} field (\texttt {ALLOW}/\texttt {DENY}/\texttt {DEFER}) and, on deferral, a \texttt {ticket\_id} the client uses to issue the subsequent \texttt {approval\_reply}}{table.4}{}}
