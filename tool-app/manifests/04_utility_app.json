{
  "app_id": "utility_app",
  "app_name": "Utility App",
  "transport": "uds_rpc",
  "endpoint": "/tmp/linux-mcp-apps/utility_app.sock",
  "demo_entrypoint": "tool-app/demo_apps/utility_app.py",
  "tools": [
    {
      "tool_id": 1,
      "name": "echo",
      "risk_tags": [],
      "operation": "echo",
      "timeout_ms": 30000,
      "description": "Echo tool that returns payload as-is for debugging and simple round-trip checks.",
      "input_schema": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "examples": [
        {
          "payload": {
            "message": "hello"
          }
        },
        {
          "payload": {
            "echo": "legacy"
          }
        }
      ]
    }
  ]
}
