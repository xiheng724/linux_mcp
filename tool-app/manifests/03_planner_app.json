{
  "app_id": "planner_app",
  "app_name": "Planner App",
  "transport": "uds_rpc",
  "endpoint": "/tmp/linux-mcp-apps/planner_app.sock",
  "demo_entrypoint": "tool-app/demo_apps/planner_app.py",
  "tools": [
    {
      "tool_id": 9,
      "name": "task_add",
      "risk_tags": [
        "filesystem_write",
        "system_mutation"
      ],
      "operation": "task_add",
      "timeout_ms": 30000,
      "description": "Create a task with optional project, priority, due-date text, and notes.",
      "input_schema": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "project": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "due_date": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "title": "Review manifest changes",
            "project": "linux-mcp",
            "priority": "high",
            "due_date": "tomorrow"
          }
        },
        {
          "payload": {
            "title": "Buy groceries",
            "notes": "milk and eggs"
          }
        }
      ]
    },
    {
      "tool_id": 10,
      "name": "task_list",
      "risk_tags": [
        "sensitive_read"
      ],
      "operation": "task_list",
      "timeout_ms": 30000,
      "description": "Browse tasks with optional project, status, priority, free-text query, and result limit filters, ordered by recency.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "project": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "project": "linux-mcp",
            "status": "open",
            "limit": 10
          }
        },
        {
          "payload": {
            "query": "manifest review",
            "priority": "high"
          }
        }
      ]
    },
    {
      "tool_id": 11,
      "name": "task_update",
      "risk_tags": [
        "filesystem_write",
        "system_mutation"
      ],
      "operation": "task_update",
      "timeout_ms": 30000,
      "description": "Update one task by exact task identifier, including status, priority, due date, title, and notes. Use a task identifier from task_list when the user did not provide a reliable exact ID.",
      "input_schema": {
        "type": "object",
        "required": [
          "task_id"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "due_date": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "task_id": "linux-mcp-20260401-120500",
            "status": "done"
          }
        },
        {
          "payload": {
            "task_id": "inbox-20260401-121000",
            "priority": "medium",
            "notes": "Waiting for review"
          }
        }
      ]
    }
  ]
}
