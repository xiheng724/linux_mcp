{
  "app_id": "calculator_app",
  "app_name": "Calculator App",
  "transport": "uds_rpc",
  "endpoint": "/tmp/linux-mcp-apps/calculator_app.sock",
  "demo_entrypoint": "tool-app/demo_apps/calculator_app.py",
  "tools": [
    {
      "tool_id": 5,
      "name": "calc",
      "risk_tags": [],
      "operation": "calc",
      "timeout_ms": 30000,
      "description": "Evaluate arithmetic expressions for quick calculations.",
      "input_schema": {
        "type": "object",
        "properties": {
          "expression": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "examples": [
        {
          "payload": {
            "expression": "(21 + 7) * 3"
          }
        },
        {
          "payload": {
            "expression": "100 / 4 + 6"
          }
        }
      ]
    }
  ]
}
