{
  "app_id": "desktop_app",
  "app_name": "Desktop App",
  "transport": "uds_rpc",
  "endpoint": "/tmp/linux-mcp-apps/desktop_app.sock",
  "demo_entrypoint": "tool-app/demo_apps/desktop_app.py",
  "tools": [
    {
      "tool_id": 12,
      "name": "desktop_snapshot",
      "risk_tags": [],
      "operation": "desktop_snapshot",
      "timeout_ms": 30000,
      "description": "Get practical desktop and host status including time, uptime, load, memory, and disk usage.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {}
        },
        {
          "payload": {
            "path": "."
          }
        }
      ]
    },
    {
      "tool_id": 13,
      "name": "open_url",
      "risk_tags": [
        "external_network",
        "system_mutation"
      ],
      "operation": "open_url",
      "timeout_ms": 30000,
      "description": "Open a web URL in the default desktop browser or handler.",
      "input_schema": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "url": "https://example.com"
          }
        },
        {
          "payload": {
            "url": "https://github.com"
          }
        }
      ]
    },
    {
      "tool_id": 14,
      "name": "show_notification",
      "risk_tags": [
        "system_mutation"
      ],
      "operation": "show_notification",
      "timeout_ms": 30000,
      "description": "Show a desktop notification with title and optional body text.",
      "input_schema": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "title": "Build finished",
            "body": "All checks passed"
          }
        },
        {
          "payload": {
            "title": "Reminder",
            "body": "Standup starts in 10 minutes"
          }
        }
      ]
    },
    {
      "tool_id": 43,
      "name": "write_host_text_file",
      "risk_tags": [
        "filesystem_write",
        "system_mutation",
        "irreversible"
      ],
      "operation": "write_host_text_file",
      "timeout_ms": 30000,
      "description": "Create or overwrite a text file on the real Linux host filesystem, including paths under ~/Desktop or other home directories outside the repo root.",
      "path_semantics": {
        "path": "host_any"
      },
      "approval_policy": {
        "user_confirmation": {
          "when": "path_outside_repo",
          "path_fields": [
            "path"
          ],
          "reason": "host filesystem write outside repo root"
        }
      },
      "input_schema": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "overwrite": {
            "type": "boolean"
          },
          "create_parents": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "path": "~/Desktop/lxh.txt",
            "content": "",
            "overwrite": true
          }
        },
        {
          "payload": {
            "path": "~/Documents/todo.txt",
            "content": "buy milk",
            "overwrite": true
          }
        }
      ]
    }
  ]
}
