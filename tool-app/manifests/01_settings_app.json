{
  "app_id": "settings_app",
  "app_name": "Settings App",
  "mode": "uds_service",
  "endpoint": "/tmp/linux-mcp-apps/settings_app.sock",
  "service_path": "tool-app/app_service.py",
  "app_impl": "tool-app/apps/settings_app.py",
  "tools": [
    {
      "tool_id": 2,
      "name": "cpu_burn",
      "perm": 1,
      "cost": 3,
      "handler": "cpu_burn",
      "description": "Burn CPU in user-space for a bounded duration in milliseconds.",
      "input_schema": {
        "type": "object",
        "required": [
          "ms"
        ],
        "properties": {
          "ms": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "ms": 200
          }
        },
        {
          "payload": {
            "ms": 50
          }
        }
      ]
    },
    {
      "tool_id": 4,
      "name": "sys_info",
      "perm": 1,
      "cost": 1,
      "handler": "sys_info",
      "description": "Get practical host diagnostics: hostname, kernel/platform, load average, memory, disk usage, and uptime.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "examples": [
        {
          "payload": {}
        },
        {
          "payload": {
            "path": "."
          }
        }
      ]
    },
    {
      "tool_id": 8,
      "name": "time_now",
      "perm": 1,
      "cost": 1,
      "handler": "time_now",
      "description": "Return current local/UTC date-time and epoch timestamp.",
      "input_schema": {
        "type": "object",
        "properties": {
          "timezone": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "examples": [
        {
          "payload": {
            "timezone": "local"
          }
        },
        {
          "payload": {
            "timezone": "utc"
          }
        }
      ]
    },
    {
      "tool_id": 9,
      "name": "volume_control",
      "perm": 1,
      "cost": 1,
      "handler": "volume_control",
      "description": "Get or adjust system output volume using local audio backend (pactl/amixer).",
      "input_schema": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string"
          },
          "level": {
            "type": "integer"
          },
          "step": {
            "type": "integer"
          }
        },
        "additionalProperties": true
      },
      "examples": [
        {
          "payload": {
            "action": "get"
          }
        },
        {
          "payload": {
            "action": "set",
            "level": 40
          }
        },
        {
          "payload": {
            "action": "change",
            "step": -10
          }
        }
      ]
    }
  ]
}
