{
  "app_id": "file_manager_app",
  "app_name": "File Manager App",
  "transport": "uds_rpc",
  "endpoint": "/tmp/linux-mcp-apps/file_manager_app.sock",
  "demo_entrypoint": "tool-app/demo_apps/file_manager_app.py",
  "tools": [
    {
      "tool_id": 3,
      "name": "text_stats",
      "perm": 1,
      "cost": 1,
      "operation": "text_stats",
      "timeout_ms": 30000,
      "description": "Compute text statistics (chars/words/lines) from payload text.",
      "input_schema": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "text": "hello world"
          }
        },
        {
          "payload": {
            "text": "line1\\nline2"
          }
        }
      ]
    },
    {
      "tool_id": 6,
      "name": "file_preview",
      "perm": 1,
      "cost": 1,
      "operation": "file_preview",
      "timeout_ms": 30000,
      "description": "Preview text files from this repository with line limits and safe path checks.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "max_lines": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "examples": [
        {
          "payload": {
            "path": "README.md",
            "max_lines": 20
          }
        },
        {
          "payload": {
            "path": "llm-app/cli.py",
            "max_lines": 30
          }
        }
      ]
    },
    {
      "tool_id": 7,
      "name": "hash_text",
      "perm": 1,
      "cost": 1,
      "operation": "hash_text",
      "timeout_ms": 30000,
      "description": "Generate SHA-256/SHA-1/MD5 digests for text content.",
      "input_schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "algorithm": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "examples": [
        {
          "payload": {
            "text": "hello",
            "algorithm": "sha256"
          }
        },
        {
          "payload": {
            "text": "linux-mcp",
            "algorithm": "md5"
          }
        }
      ]
    },
    {
      "tool_id": 10,
      "name": "file_create",
      "perm": 1,
      "cost": 1,
      "operation": "file_create",
      "timeout_ms": 30000,
      "description": "Create or overwrite a text file under repository root with safe path checks.",
      "input_schema": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "overwrite": {
            "type": "boolean"
          },
          "create_parents": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "path": "tmp/demo.txt",
            "content": "hello"
          }
        },
        {
          "payload": {
            "path": "notes/today.md",
            "content": "# Today",
            "overwrite": true
          }
        }
      ]
    },
    {
      "tool_id": 11,
      "name": "file_list",
      "perm": 1,
      "cost": 1,
      "operation": "file_list",
      "timeout_ms": 30000,
      "description": "List directory entries or inspect a file under repository root with safe path checks.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "max_entries": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "path": ".",
            "max_entries": 50
          }
        },
        {
          "payload": {
            "path": "tool-app"
          }
        }
      ]
    },
    {
      "tool_id": 12,
      "name": "file_delete",
      "perm": 1,
      "cost": 1,
      "operation": "file_delete",
      "timeout_ms": 30000,
      "description": "Delete a file (or directory with recursive=true) under repository root with safety checks.",
      "input_schema": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "recursive": {
            "type": "boolean"
          },
          "allow_missing": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "path": "tmp/demo_created_by_mcp.txt"
          }
        },
        {
          "payload": {
            "path": "tmp/old_logs",
            "recursive": true
          }
        }
      ]
    },
    {
      "tool_id": 13,
      "name": "file_copy",
      "perm": 1,
      "cost": 1,
      "operation": "file_copy",
      "timeout_ms": 30000,
      "description": "Copy a file under repository root with safe path checks.",
      "input_schema": {
        "type": "object",
        "required": [
          "src_path",
          "dst_path"
        ],
        "properties": {
          "src_path": {
            "type": "string"
          },
          "dst_path": {
            "type": "string"
          },
          "overwrite": {
            "type": "boolean"
          },
          "create_parents": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "src_path": "README.md",
            "dst_path": "tmp/README.copy.md"
          }
        },
        {
          "payload": {
            "src_path": "tmp/a.txt",
            "dst_path": "tmp/b.txt",
            "overwrite": true
          }
        }
      ]
    },
    {
      "tool_id": 14,
      "name": "file_rename",
      "perm": 1,
      "cost": 1,
      "operation": "file_rename",
      "timeout_ms": 30000,
      "description": "Rename or move a file under repository root with safe path checks.",
      "input_schema": {
        "type": "object",
        "required": [
          "src_path",
          "dst_path"
        ],
        "properties": {
          "src_path": {
            "type": "string"
          },
          "dst_path": {
            "type": "string"
          },
          "overwrite": {
            "type": "boolean"
          },
          "create_parents": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "src_path": "tmp/a.txt",
            "dst_path": "tmp/a_renamed.txt"
          }
        },
        {
          "payload": {
            "src_path": "tmp/a.txt",
            "dst_path": "tmp/archive/a.txt",
            "create_parents": true
          }
        }
      ]
    }
  ]
}
