{
  "app_id": "file_manager_app",
  "app_name": "File Manager App",
  "provider_id": "file-manager-provider",
  "provider_type": "filesystem",
  "trust_class": "local",
  "auth_mode": "local-process",
  "broker_domain": "file",
  "mode": "uds_service",
  "endpoint": "/tmp/linux-mcp-apps/file_manager_app.sock",
  "service_path": "tool-app/app_service.py",
  "app_impl": "tool-app/apps/file_manager_app.py",
  "tools": [
    {
      "tool_id": 3,
      "name": "text_stats",
      "perm": 1,
      "cost": 1,
      "handler": "text_stats",
      "action_name": "compute_text_stats",
      "capability_domain": "info.lookup",
      "risk_level": 1,
      "executor_type": "broker-uds",
      "validation_policy": "json_schema_v1",
      "description": "Compute text statistics (chars/words/lines) from payload text.",
      "input_schema": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "text": "hello world"
          }
        },
        {
          "payload": {
            "text": "line1\\nline2"
          }
        }
      ]
    },
    {
      "tool_id": 6,
      "name": "file_preview",
      "perm": 1,
      "cost": 1,
      "handler": "file_preview",
      "action_name": "preview_text_file",
      "capability_domain": "file.read",
      "risk_level": 3,
      "executor_type": "broker-uds",
      "validation_policy": "json_schema_v1",
      "description": "Preview text files from this repository with line limits and safe path checks.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "max_lines": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "examples": [
        {
          "payload": {
            "path": "README.md",
            "max_lines": 20
          }
        },
        {
          "payload": {
            "path": "llm-app/cli.py",
            "max_lines": 30
          }
        }
      ]
    },
    {
      "tool_id": 7,
      "name": "hash_text",
      "perm": 1,
      "cost": 1,
      "handler": "hash_text",
      "action_name": "hash_text_payload",
      "capability_domain": "info.lookup",
      "risk_level": 1,
      "executor_type": "broker-uds",
      "validation_policy": "json_schema_v1",
      "description": "Generate SHA-256/SHA-1/MD5 digests for text content.",
      "input_schema": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "algorithm": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "examples": [
        {
          "payload": {
            "text": "hello",
            "algorithm": "sha256"
          }
        },
        {
          "payload": {
            "text": "linux-mcp",
            "algorithm": "md5"
          }
        }
      ]
    },
    {
      "tool_id": 10,
      "name": "file_create",
      "perm": 1,
      "cost": 1,
      "handler": "file_create",
      "action_name": "create_file",
      "capability_domain": "file.write",
      "risk_level": 8,
      "executor_type": "broker-isolated-uds",
      "validation_policy": "json_schema_strict_v1",
      "description": "Create or overwrite a text file under repository root with safe path checks.",
      "input_schema": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "overwrite": {
            "type": "boolean"
          },
          "create_parents": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "path": "tmp/demo.txt",
            "content": "hello"
          }
        },
        {
          "payload": {
            "path": "notes/today.md",
            "content": "# Today",
            "overwrite": true
          }
        }
      ]
    },
    {
      "tool_id": 11,
      "name": "file_list",
      "perm": 1,
      "cost": 1,
      "handler": "file_list",
      "action_name": "list_files",
      "capability_domain": "file.read",
      "risk_level": 3,
      "executor_type": "broker-uds",
      "validation_policy": "json_schema_v1",
      "description": "List directory entries or inspect a file under repository root with safe path checks.",
      "input_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "max_entries": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "path": ".",
            "max_entries": 50
          }
        },
        {
          "payload": {
            "path": "tool-app"
          }
        }
      ]
    },
    {
      "tool_id": 12,
      "name": "file_delete",
      "perm": 1,
      "cost": 1,
      "handler": "file_delete",
      "action_name": "delete_file",
      "capability_domain": "file.write",
      "risk_level": 8,
      "executor_type": "broker-isolated-uds",
      "validation_policy": "json_schema_strict_v1",
      "description": "Delete a file (or directory with recursive=true) under repository root with safety checks.",
      "input_schema": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "recursive": {
            "type": "boolean"
          },
          "allow_missing": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "path": "tmp/demo_created_by_mcp.txt"
          }
        },
        {
          "payload": {
            "path": "tmp/old_logs",
            "recursive": true
          }
        }
      ]
    },
    {
      "tool_id": 13,
      "name": "file_copy",
      "perm": 1,
      "cost": 1,
      "handler": "file_copy",
      "action_name": "copy_file",
      "capability_domain": "file.write",
      "risk_level": 8,
      "executor_type": "broker-isolated-uds",
      "validation_policy": "json_schema_strict_v1",
      "description": "Copy a file under repository root with safe path checks.",
      "input_schema": {
        "type": "object",
        "required": [
          "src_path",
          "dst_path"
        ],
        "properties": {
          "src_path": {
            "type": "string"
          },
          "dst_path": {
            "type": "string"
          },
          "overwrite": {
            "type": "boolean"
          },
          "create_parents": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "src_path": "README.md",
            "dst_path": "tmp/README.copy.md"
          }
        },
        {
          "payload": {
            "src_path": "tmp/a.txt",
            "dst_path": "tmp/b.txt",
            "overwrite": true
          }
        }
      ]
    },
    {
      "tool_id": 14,
      "name": "file_rename",
      "perm": 1,
      "cost": 1,
      "handler": "file_rename",
      "action_name": "rename_file",
      "capability_domain": "file.write",
      "risk_level": 8,
      "executor_type": "broker-isolated-uds",
      "validation_policy": "json_schema_strict_v1",
      "description": "Rename or move a file under repository root with safe path checks.",
      "input_schema": {
        "type": "object",
        "required": [
          "src_path",
          "dst_path"
        ],
        "properties": {
          "src_path": {
            "type": "string"
          },
          "dst_path": {
            "type": "string"
          },
          "overwrite": {
            "type": "boolean"
          },
          "create_parents": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "src_path": "tmp/a.txt",
            "dst_path": "tmp/a_renamed.txt"
          }
        },
        {
          "payload": {
            "src_path": "tmp/a.txt",
            "dst_path": "tmp/archive/a.txt",
            "create_parents": true
          }
        }
      ]
    }
  ]
}
