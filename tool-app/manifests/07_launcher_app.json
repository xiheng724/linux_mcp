{
  "app_id": "launcher_app",
  "app_name": "Launcher App",
  "transport": "uds_rpc",
  "endpoint": "/tmp/linux-mcp-apps/launcher_app.sock",
  "demo_entrypoint": "tool-app/demo_apps/launcher_app.py",
  "tools": [
    {
      "tool_id": 21,
      "name": "list_launchable_apps",
      "risk_tags": [
        "sensitive_read"
      ],
      "operation": "list_launchable_apps",
      "timeout_ms": 30000,
      "description": "List installed desktop applications discovered from .desktop files, optionally filtered by query.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "query": "calendar",
            "limit": 10
          }
        },
        {
          "payload": {
            "query": "firefox"
          }
        }
      ]
    },
    {
      "tool_id": 22,
      "name": "launch_app",
      "risk_tags": [
        "system_mutation"
      ],
      "operation": "launch_app",
      "timeout_ms": 30000,
      "description": "Launch a real installed desktop application by desktop_id, app name, or executable, with an optional target path or URL.",
      "input_schema": {
        "type": "object",
        "properties": {
          "desktop_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "executable": {
            "type": "string"
          },
          "target": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "name": "Calendar"
          }
        },
        {
          "payload": {
            "desktop_id": "org.gnome.Nautilus.desktop",
            "target": "."
          }
        }
      ]
    },
    {
      "tool_id": 23,
      "name": "open_with_app",
      "risk_tags": [
        "system_mutation"
      ],
      "operation": "open_with_app",
      "timeout_ms": 30000,
      "description": "Open a specific file path or URL with a chosen installed desktop application.",
      "input_schema": {
        "type": "object",
        "required": [
          "target"
        ],
        "properties": {
          "target": {
            "type": "string"
          },
          "desktop_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "executable": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "examples": [
        {
          "payload": {
            "target": "README.md",
            "name": "Visual Studio Code"
          }
        },
        {
          "payload": {
            "target": "https://github.com",
            "executable": "firefox"
          }
        }
      ]
    }
  ]
}
