{
  "display_name": "Utility Provider",
  "provider_id": "utility-provider",
  "provider_type": "utility",
  "trust_class": "local",
  "auth_mode": "local-process",
  "broker_domain": "info",
  "mode": "uds_service",
  "endpoint": "/tmp/linux-mcp-providers/utility_provider.sock",
  "provider_impl": "provider-app/providers/utility_provider.py",
  "actions": [
    {
      "action_id": 1,
      "name": "echo",
      "perm": 1,
      "cost": 1,
      "handler": "echo",
      "action_name": "echo_payload",
      "capability_domain": "info.lookup",
      "risk_level": 1,
      "side_effect": false,
      "auth_required": false,
      "data_sensitivity": "low",
      "executor_type": "broker-uds",
      "validation_policy": "json_schema_v1",
      "parameter_schema_id": "info.lookup:echo_payload:v1",
      "selection_priority": 20,
      "description": "Echo tool that returns payload as-is for debugging and simple round-trip checks.",
      "input_schema": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "intent_tags": [
        "echo",
        "repeat",
        "debug",
        "roundtrip",
        "message"
      ],
      "arg_hints": {
        "message": {
          "kind": "quoted_or_tail",
          "after": [
            "echo",
            "message"
          ],
          "strip_prefixes": [
            "echo"
          ]
        }
      },
      "examples": [
        {
          "intent": "echo hello",
          "payload": {
            "message": "hello"
          }
        },
        {
          "intent": "echo 'legacy'",
          "payload": {
            "message": "legacy"
          }
        }
      ]
    }
  ]
}
