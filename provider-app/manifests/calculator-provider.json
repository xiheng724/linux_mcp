{
  "display_name": "Calculator Provider",
  "provider_id": "calculator-provider",
  "provider_type": "calculator",
  "trust_class": "local",
  "auth_mode": "local-process",
  "broker_domain": "info",
  "mode": "uds_service",
  "endpoint": "/tmp/linux-mcp-providers/calculator_provider.sock",
  "provider_impl": "provider-app/providers/calculator_provider.py",
  "actions": [
    {
      "action_id": 5,
      "name": "calc",
      "perm": 1,
      "cost": 1,
      "handler": "calc",
      "action_name": "evaluate_expression",
      "capability_domain": "info.lookup",
      "risk_level": 2,
      "side_effect": false,
      "auth_required": false,
      "data_sensitivity": "low",
      "executor_type": "broker-uds",
      "validation_policy": "json_schema_v1",
      "parameter_schema_id": "info.lookup:evaluate_expression:v1",
      "selection_priority": 62,
      "description": "Evaluate arithmetic expressions for quick calculations.",
      "input_schema": {
        "type": "object",
        "properties": {
          "expression": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "intent_tags": [
        "calculate",
        "math",
        "arithmetic",
        "expression",
        "compute",
        "equation"
      ],
      "arg_hints": {
        "expression": {
          "kind": "expression"
        },
        "message": {
          "kind": "tail_text",
          "default": ""
        }
      },
      "examples": [
        {
          "intent": "calculate (21 + 7) * 3",
          "payload": {
            "expression": "(21 + 7) * 3"
          }
        },
        {
          "intent": "what is 100 / 4 + 6",
          "payload": {
            "expression": "100 / 4 + 6"
          }
        }
      ]
    }
  ]
}
