      "action_id": 3,
      "name": "text_stats",
      "perm": 1,
      "cost": 1,
      "handler": "text_stats",
      "action_name": "compute_text_stats",
      "capability_domain": "info.lookup",
      "risk_level": 1,
      "side_effect": false,
      "auth_required": false,
      "data_sensitivity": "low",
      "executor_type": "broker-uds",
      "validation_policy": "json_schema_v1",
      "parameter_schema_id": "info.lookup:compute_text_stats:v1",
      "selection_priority": 50,
      "description": "Compute text statistics (chars/words/lines) from payload text.",
      "input_schema": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "intent_tags": [
        "count",
        "statistics",
        "words",
        "lines",
        "characters",
        "text"
      ],
      "arg_hints": {
        "text": {
          "kind": "quoted_or_tail",
          "after": [
            "text",
            "message",
            "content"
          ],
          "strip_prefixes": [
            "count words in",
            "count lines in",
            "count characters in",
            "compute text stats for"
          ]
        }
      },
      "examples": [
        {
          "intent": "count words in 'hello world'",
          "payload": {
            "text": "hello world"
          }
        },
        {
          "intent": "compute text statistics for 'line1\\nline2'",
          "payload": {
            "text": "line1\\nline2"
          }
        }
      ]
    },
