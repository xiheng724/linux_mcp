          "aliases_by_choice": {
            "sha256": [
              "sha256",
              "sha-256"
            ],
            "sha1": [
              "sha1",
              "sha-1"
            ],
            "md5": [
              "md5"
            ]
          },
          "default": "sha256"
        }
      },
      "examples": [
        {
          "intent": "hash text hello with sha256",
          "payload": {
            "text": "hello",
            "algorithm": "sha256"
          }
        },
