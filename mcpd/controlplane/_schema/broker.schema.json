{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "mcpd/v1"
    },
    "kind": {
      "const": "BrokerDefinition"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "required": [
        "selection_policy",
        "runtime_identity_mode",
        "policy_controlled"
      ],
      "properties": {
        "selection_policy": {
          "type": "object",
          "required": [
            "require_provider_availability",
            "prefer_manifest_priority",
            "prefer_example_matches",
            "prefer_lower_risk_on_tie",
            "allow_preferred_provider_high_risk"
          ],
          "properties": {
            "require_provider_availability": {
              "type": "boolean"
            },
            "prefer_manifest_priority": {
              "type": "boolean"
            },
            "prefer_example_matches": {
              "type": "boolean"
            },
            "prefer_lower_risk_on_tie": {
              "type": "boolean"
            },
            "allow_preferred_provider_high_risk": {
              "type": "boolean"
            },
            "enable_semantic_rerank": {
              "type": "boolean"
            },
            "semantic_ambiguity_threshold": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000
            },
            "semantic_score_weight": {
              "type": "number",
              "minimum": 0,
              "maximum": 10
            }
          },
          "additionalProperties": false
        },
        "runtime_identity_mode": {
          "type": "string"
        },
        "policy_controlled": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
