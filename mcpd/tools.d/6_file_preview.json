{
  "tool_id": 6,
  "name": "file_preview",
  "perm": 1,
  "cost": 1,
  "app_path": "tool-app/file_preview_app.py",
  "description": "Preview text files from this repository with line limits and safe path checks.",
  "input_schema": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string"
      },
      "max_lines": {
        "type": "integer"
      },
      "message": {
        "type": "string"
      }
    },
    "additionalProperties": true
  },
  "examples": [
    {
      "payload": {
        "path": "README.md",
        "max_lines": 20
      }
    },
    {
      "payload": {
        "path": "llm-app/cli.py",
        "max_lines": 30
      }
    }
  ]
}
